# Shared Docker Compose configuration (DEV-ONLY values, not for production).
# These placeholder secrets are intentionally committed so the stack is
# reproducible with a single `docker compose up`.

# --- Keycloak ---
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.3
KC_PORT=8081
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- Realm / OIDC client (must match keycloak/realm-export.json) ---
KEYCLOAK_REALM=web
KEYCLOAK_CLIENT_ID=nextjs-frontend
KEYCLOAK_CLIENT_SECRET=nextjs-frontend-secret-dev
# Single issuer used by BOTH the browser and the backend.
# Requires `127.0.0.1 keycloak` in /etc/hosts (see README).
KEYCLOAK_ISSUER=http://keycloak:8081/realms/web

# --- Application ports ---
FRONTEND_PORT=3000
BACKEND_PORT=8080
